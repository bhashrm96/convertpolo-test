{%- comment -%}
  qsw-back-btn — Back button for Quick Support Widget view navigation

  Used in:
    • View 2 (question list)  → id: qsw-back-questions
    • View 3 (answer view)    → id: qsw-back-answer

  Parameters:
    btn_id  {string}  Required. The HTML id attribute for this button instance.
                      JS references each button by its unique id to attach
                      the correct back-navigation behaviour.
{%- endcomment -%}
<button id="{{ btn_id }}" class="qsw-back-btn" type="button" aria-label="Back">
  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17 9H5.414l3.293-3.293a.999.999 0 1 0-1.414-1.414l-5 5a.999.999 0 0 0 0 1.414l5 5a.997.997 0 0 0 1.414 0 .999.999 0 0 0 0-1.414L5.414 11H17a1 1 0 1 0 0-2z"/></svg>
</button>
